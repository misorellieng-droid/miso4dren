# Copie para .env.local e preencha com as chaves do projeto Supabase do miso4dren.
# Sem essas variáveis, o app funciona normalmente para os módulos de cálculo
# (funções puras, 100% client-side) — só a persistência em nuvem (obras,
# import de rede/bacias, resultados) fica indisponível.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
